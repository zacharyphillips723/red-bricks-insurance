{
  "datasets": [
    {
      "name": "ds_total_scored",
      "displayName": "Total Scored Claims",
      "queryLines": [
        "SELECT COUNT(*) AS total_scored FROM red_bricks_insurance_catalog.analytics.fwa_model_inference"
      ]
    },
    {
      "name": "ds_high_risk_count",
      "displayName": "High Risk Claims",
      "queryLines": [
        "SELECT COUNT(*) AS high_risk_count FROM red_bricks_insurance_catalog.analytics.fwa_model_inference WHERE ml_risk_tier = 'High'"
      ]
    },
    {
      "name": "ds_model_version",
      "displayName": "Model Version",
      "queryLines": [
        "SELECT MAX(model_version) AS current_version FROM red_bricks_insurance_catalog.analytics.fwa_ml_predictions"
      ]
    },
    {
      "name": "ds_prediction_distribution",
      "displayName": "Prediction Distribution by Risk Tier",
      "queryLines": [
        "SELECT ml_risk_tier, COUNT(*) AS claim_count, ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER (), 1) AS pct FROM red_bricks_insurance_catalog.analytics.fwa_model_inference GROUP BY ml_risk_tier ORDER BY CASE ml_risk_tier WHEN 'High' THEN 1 WHEN 'Medium' THEN 2 ELSE 3 END"
      ]
    },
    {
      "name": "ds_probability_histogram",
      "displayName": "Fraud Probability Distribution",
      "queryLines": [
        "SELECT ROUND(ml_fraud_probability, 1) AS probability_bucket, COUNT(*) AS claim_count FROM red_bricks_insurance_catalog.analytics.fwa_model_inference GROUP BY ROUND(ml_fraud_probability, 1) ORDER BY probability_bucket"
      ]
    },
    {
      "name": "ds_risk_by_lob",
      "displayName": "Risk Tier by Line of Business",
      "queryLines": [
        "SELECT line_of_business, ml_risk_tier, COUNT(*) AS claim_count FROM red_bricks_insurance_catalog.analytics.fwa_model_inference WHERE line_of_business IS NOT NULL GROUP BY line_of_business, ml_risk_tier ORDER BY line_of_business, ml_risk_tier"
      ]
    },
    {
      "name": "ds_risk_by_claim_type",
      "displayName": "Risk Tier by Claim Type",
      "queryLines": [
        "SELECT claim_type, ml_risk_tier, COUNT(*) AS claim_count, ROUND(AVG(billed_amount), 2) AS avg_billed FROM red_bricks_insurance_catalog.analytics.fwa_model_inference GROUP BY claim_type, ml_risk_tier ORDER BY claim_type"
      ]
    },
    {
      "name": "ds_prediction_by_month",
      "displayName": "Predictions Over Time",
      "queryLines": [
        "SELECT service_year_month, ml_risk_tier, COUNT(*) AS claim_count FROM red_bricks_insurance_catalog.analytics.fwa_model_inference WHERE service_year_month IS NOT NULL GROUP BY service_year_month, ml_risk_tier ORDER BY service_year_month"
      ]
    },
    {
      "name": "ds_high_risk_providers",
      "displayName": "High Risk Providers",
      "queryLines": [
        "SELECT provider_npi, COUNT(*) AS high_risk_claims, ROUND(AVG(ml_fraud_probability), 3) AS avg_fraud_prob, ROUND(SUM(billed_amount), 0) AS total_billed FROM red_bricks_insurance_catalog.analytics.fwa_model_inference WHERE ml_risk_tier = 'High' GROUP BY provider_npi ORDER BY high_risk_claims DESC LIMIT 20"
      ]
    },
    {
      "name": "ds_feature_drift",
      "displayName": "Feature Drift Metrics",
      "queryLines": [
        "SELECT column_name, drift_type, ROUND(ks_test.statistic, 4) AS ks_statistic, ROUND(ks_test.pvalue, 6) AS ks_pvalue, ROUND(js_distance, 4) AS js_distance, ROUND(population_stability_index, 4) AS psi, CASE WHEN population_stability_index > 0.2 THEN 'DRIFT' WHEN population_stability_index > 0.1 THEN 'WARNING' ELSE 'STABLE' END AS drift_status FROM red_bricks_insurance_catalog.analytics.fwa_model_inference_drift_metrics WHERE drift_type IS NOT NULL ORDER BY js_distance DESC"
      ]
    },
    {
      "name": "ds_profile_metrics",
      "displayName": "Profile Metrics Summary",
      "queryLines": [
        "SELECT column_name, data_type, ROUND(avg, 4) AS avg_value, ROUND(stddev, 4) AS stddev_value, ROUND(min, 4) AS min_value, ROUND(max, 4) AS max_value, num_nulls, distinct_count FROM red_bricks_insurance_catalog.analytics.fwa_model_inference_profile_metrics WHERE column_name NOT IN ('ml_risk_tier', 'claim_id', 'member_id', 'provider_npi') ORDER BY column_name"
      ]
    },
    {
      "name": "ds_governance_audit",
      "displayName": "Governance Audit Trail",
      "queryLines": [
        "SELECT check_timestamp, model_version_champion, ROUND(psi_billed_amount, 4) AS psi_billed, ROUND(psi_ml_fraud_probability, 4) AS psi_fraud_prob, total_requests_7d, total_errors_7d, alert_count, alerts_json, mlflow_run_id FROM red_bricks_insurance_catalog.analytics.fwa_governance_audit ORDER BY check_timestamp DESC LIMIT 20"
      ]
    },
    {
      "name": "ds_low_confidence",
      "displayName": "Low Confidence Claims",
      "queryLines": [
        "SELECT claim_id, member_id, provider_npi, billed_amount, ml_fraud_probability, ml_risk_tier, claim_type FROM red_bricks_insurance_catalog.analytics.fwa_model_inference WHERE ml_fraud_probability BETWEEN 0.35 AND 0.65 ORDER BY ml_fraud_probability DESC LIMIT 50"
      ]
    },
    {
      "name": "ds_serving_volume",
      "displayName": "Serving Request Volume",
      "queryLines": [
        "SELECT date_trunc('hour', request_time) AS hour, served_entity_name, COUNT(*) AS request_count, SUM(CASE WHEN status_code != 200 THEN 1 ELSE 0 END) AS error_count FROM system.serving.served_model_requests WHERE endpoint_name = 'fwa_scorer_demo' AND request_time >= CURRENT_DATE() - INTERVAL 7 DAYS GROUP BY 1, 2 ORDER BY 1 DESC, 2"
      ]
    },
    {
      "name": "ds_serving_latency",
      "displayName": "Serving Latency Percentiles",
      "queryLines": [
        "SELECT date_trunc('hour', request_time) AS hour, ROUND(PERCENTILE(execution_time_ms, 0.50), 0) AS p50_ms, ROUND(PERCENTILE(execution_time_ms, 0.95), 0) AS p95_ms, ROUND(PERCENTILE(execution_time_ms, 0.99), 0) AS p99_ms FROM system.serving.served_model_requests WHERE endpoint_name = 'fwa_scorer_demo' AND request_time >= CURRENT_DATE() - INTERVAL 7 DAYS GROUP BY 1 ORDER BY 1 DESC"
      ]
    },
    {
      "name": "ds_serving_error_rate",
      "displayName": "Serving Error Rate",
      "queryLines": [
        "SELECT DATE(request_time) AS date, COUNT(*) AS total_requests, SUM(CASE WHEN status_code != 200 THEN 1 ELSE 0 END) AS errors, ROUND(SUM(CASE WHEN status_code != 200 THEN 1 ELSE 0 END) * 100.0 / COUNT(*), 2) AS error_rate_pct FROM system.serving.served_model_requests WHERE endpoint_name = 'fwa_scorer_demo' AND request_time >= CURRENT_DATE() - INTERVAL 7 DAYS GROUP BY 1 ORDER BY 1 DESC"
      ]
    },
    {
      "name": "ds_serving_daily_summary",
      "displayName": "Daily Request Summary",
      "queryLines": [
        "SELECT DATE(request_time) AS date, COUNT(*) AS total_requests, COUNT(DISTINCT served_entity_name) AS served_entities, ROUND(AVG(execution_time_ms), 0) AS avg_latency_ms, ROUND(PERCENTILE(execution_time_ms, 0.95), 0) AS p95_latency_ms, SUM(CASE WHEN status_code != 200 THEN 1 ELSE 0 END) AS errors FROM system.serving.served_model_requests WHERE endpoint_name = 'fwa_scorer_demo' AND request_time >= CURRENT_DATE() - INTERVAL 30 DAYS GROUP BY 1 ORDER BY 1 DESC"
      ]
    }
  ],
