{
  "datasets": [
    {
      "name": "ds_gateway_totals",
      "displayName": "AI Gateway Summary (7d)",
      "queryLines": [
        "SELECT COUNT(*) AS total_requests, SUM(CASE WHEN status_code = '200' THEN 1 ELSE 0 END) AS successful_requests, SUM(CASE WHEN status_code != '200' THEN 1 ELSE 0 END) AS failed_requests, ROUND(AVG(latency_ms), 0) AS avg_latency_ms, ROUND(PERCENTILE(latency_ms, 0.5), 0) AS p50_latency_ms, ROUND(PERCENTILE(latency_ms, 0.95), 0) AS p95_latency_ms FROM system.ai_gateway.usage WHERE event_time >= CURRENT_TIMESTAMP() - INTERVAL 7 DAYS"
      ]
    },
    {
      "name": "ds_gateway_daily",
      "displayName": "Daily Request Volume",
      "queryLines": [
        "SELECT DATE(event_time) AS request_date, COUNT(*) AS request_count, SUM(CASE WHEN status_code = '200' THEN 1 ELSE 0 END) AS success_count, SUM(CASE WHEN status_code != '200' THEN 1 ELSE 0 END) AS error_count FROM system.ai_gateway.usage WHERE event_time >= CURRENT_TIMESTAMP() - INTERVAL 7 DAYS GROUP BY request_date ORDER BY request_date"
      ]
    },
    {
      "name": "ds_latency_daily",
      "displayName": "Daily Latency Trend",
      "queryLines": [
        "SELECT DATE(event_time) AS request_date, ROUND(AVG(latency_ms), 0) AS avg_latency_ms, ROUND(PERCENTILE(latency_ms, 0.5), 0) AS p50_latency_ms, ROUND(PERCENTILE(latency_ms, 0.95), 0) AS p95_latency_ms FROM system.ai_gateway.usage WHERE event_time >= CURRENT_TIMESTAMP() - INTERVAL 7 DAYS GROUP BY request_date ORDER BY request_date"
      ]
    },
    {
      "name": "ds_endpoint_usage",
      "displayName": "Usage by Endpoint",
      "queryLines": [
        "SELECT endpoint_name, COUNT(*) AS total_requests, ROUND(AVG(latency_ms), 0) AS avg_latency_ms, ROUND(PERCENTILE(latency_ms, 0.95), 0) AS p95_latency_ms, SUM(input_tokens) AS total_input_tokens, SUM(output_tokens) AS total_output_tokens, SUM(total_tokens) AS total_tokens, SUM(CASE WHEN status_code != '200' THEN 1 ELSE 0 END) AS errors FROM system.ai_gateway.usage WHERE event_time >= CURRENT_TIMESTAMP() - INTERVAL 7 DAYS GROUP BY endpoint_name ORDER BY total_requests DESC"
      ]
    },
    {
      "name": "ds_model_usage",
      "displayName": "Usage by Model",
      "queryLines": [
        "SELECT destination_model, COUNT(*) AS total_requests, ROUND(AVG(latency_ms), 0) AS avg_latency_ms, SUM(total_tokens) AS total_tokens, SUM(CASE WHEN status_code != '200' THEN 1 ELSE 0 END) AS errors FROM system.ai_gateway.usage WHERE event_time >= CURRENT_TIMESTAMP() - INTERVAL 7 DAYS GROUP BY destination_model ORDER BY total_requests DESC"
      ]
    },
    {
      "name": "ds_token_totals",
      "displayName": "Token Usage (7d)",
      "queryLines": [
        "SELECT SUM(input_tokens) AS total_input_tokens, SUM(output_tokens) AS total_output_tokens, SUM(total_tokens) AS total_tokens, COUNT(DISTINCT endpoint_name) AS active_endpoints FROM system.ai_gateway.usage WHERE event_time >= CURRENT_TIMESTAMP() - INTERVAL 7 DAYS"
      ]
    },
    {
      "name": "ds_token_daily",
      "displayName": "Daily Token Consumption",
      "queryLines": [
        "SELECT DATE(event_time) AS request_date, SUM(input_tokens) AS input_tokens, SUM(output_tokens) AS output_tokens, SUM(total_tokens) AS total_tokens FROM system.ai_gateway.usage WHERE event_time >= CURRENT_TIMESTAMP() - INTERVAL 7 DAYS GROUP BY request_date ORDER BY request_date"
      ]
    },
    {
      "name": "ds_recent_errors",
      "displayName": "Recent Errors",
      "queryLines": [
        "SELECT event_time, endpoint_name, destination_model, status_code, latency_ms, requester FROM system.ai_gateway.usage WHERE event_time >= CURRENT_TIMESTAMP() - INTERVAL 7 DAYS AND status_code != '200' ORDER BY event_time DESC LIMIT 50"
      ]
    },
    {
      "name": "ds_requester_usage",
      "displayName": "Usage by Requester",
      "queryLines": [
        "SELECT requester, COUNT(*) AS total_requests, SUM(total_tokens) AS total_tokens, ROUND(AVG(latency_ms), 0) AS avg_latency_ms, SUM(CASE WHEN status_code != '200' THEN 1 ELSE 0 END) AS errors FROM system.ai_gateway.usage WHERE event_time >= CURRENT_TIMESTAMP() - INTERVAL 7 DAYS GROUP BY requester ORDER BY total_requests DESC LIMIT 25"
      ]
    }
  ],
