            "spec": {"version": 3, "widgetType": "bar", "encodings": {"x": {"fieldName": "query_date", "scale": {"type": "temporal"}, "displayName": "Date"}, "y": {"fieldName": "query_count", "scale": {"type": "quantitative"}, "displayName": "Queries"}}, "frame": {"showTitle": true, "title": "SQL Query Activity (7d)"}}
          },
          "position": {"x": 0, "y": 10, "width": 6, "height": 4}
        }
      ]
    }
  ]
}
