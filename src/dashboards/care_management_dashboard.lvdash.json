{
  "datasets": [
    {
      "name": "ds_program_performance",
      "displayName": "Program Performance",
      "queryLines": [
        "SELECT program_name, program_type, line_of_business, total_enrollments, active_enrollments, completed_enrollments, withdrawn_enrollments, completion_rate_pct, avg_enrollment_days FROM red_bricks_insurance_catalog.care_management.gold_program_performance ORDER BY total_enrollments DESC"
      ]
    },
    {
      "name": "ds_program_totals",
      "displayName": "Program Summary Totals",
      "queryLines": [
        "SELECT SUM(total_enrollments) AS total_enrollments, SUM(active_enrollments) AS active_enrollments, SUM(completed_enrollments) AS completed_enrollments, ROUND(SUM(completed_enrollments) * 100.0 / NULLIF(SUM(total_enrollments), 0), 1) AS overall_completion_rate, COUNT(DISTINCT program_name) AS program_count FROM red_bricks_insurance_catalog.care_management.gold_program_performance"
      ]
    },
    {
      "name": "ds_case_manager_productivity",
      "displayName": "Case Manager Productivity",
      "queryLines": [
        "SELECT case_manager_id, total_cases, open_cases, closed_cases, avg_case_duration_days, avg_activities_per_case, avg_activity_minutes, total_assessments, assessment_completion_rate_pct FROM red_bricks_insurance_catalog.care_management.gold_case_manager_productivity ORDER BY total_cases DESC"
      ]
    },
    {
      "name": "ds_sdoh_prevalence",
      "displayName": "SDOH Prevalence by County",
      "queryLines": [
        "SELECT county, members_screened, food_insecurity_pct, housing_instability_pct, transportation_barrier_pct, social_isolation_pct, financial_strain_pct, avg_composite_score, avg_flags_per_member FROM red_bricks_insurance_catalog.care_management.gold_sdoh_prevalence ORDER BY members_screened DESC"
      ]
    },
    {
      "name": "ds_sdoh_cost_impact",
      "displayName": "SDOH Cost Impact",
      "queryLines": [
        "SELECT sdoh_status, total_sdoh_flags, member_count, avg_composite_score FROM red_bricks_insurance_catalog.care_management.gold_sdoh_cost_impact ORDER BY total_sdoh_flags"
      ]
    },
    {
      "name": "ds_sdoh_referrals",
      "displayName": "SDOH Referral Outcomes",
      "queryLines": [
        "SELECT referral_type, community_resource, total_referrals, completed, pending, in_progress, declined, completion_rate_pct FROM red_bricks_insurance_catalog.care_management.gold_sdoh_referral_outcomes ORDER BY total_referrals DESC"
      ]
    },
    {
      "name": "ds_toc_performance",
      "displayName": "Transitions of Care Performance",
      "queryLines": [
        "SELECT discharge_type, readmission_risk_tier, total_episodes, call_48hr_completion_pct, pcp_7day_completion_pct, med_rec_completion_pct, avg_readmission_risk FROM red_bricks_insurance_catalog.care_management.gold_toc_performance ORDER BY total_episodes DESC"
      ]
    },
    {
      "name": "ds_toc_barriers",
      "displayName": "TOC Barriers",
      "queryLines": [
        "SELECT barrier_type, total_occurrences, resolved_count, resolution_rate_pct FROM red_bricks_insurance_catalog.care_management.gold_toc_barriers ORDER BY total_occurrences DESC"
      ]
    },
    {
      "name": "ds_gap_closure_rates",
      "displayName": "Care Gap Closure Rates",
      "queryLines": [
        "SELECT measure_name, condition, priority, total_gaps, closed_gaps, closure_rate_pct, avg_days_to_close, total_interventions, avg_interventions_per_gap FROM red_bricks_insurance_catalog.care_management.gold_gap_closure_rates ORDER BY total_gaps DESC"
      ]
    },
    {
      "name": "ds_gap_closure_funnel",
      "displayName": "Care Gap Closure Funnel",
      "queryLines": [
        "SELECT measure_name, total_open_gaps, gaps_with_intervention, gaps_closed, intervention_rate_pct, intervention_to_closure_pct, overall_closure_rate_pct FROM red_bricks_insurance_catalog.care_management.gold_gap_closure_funnel ORDER BY total_open_gaps DESC"
      ]
    },
    {
      "name": "ds_program_outcomes",
      "displayName": "Program Outcomes",
      "queryLines": [
        "SELECT program_name, line_of_business, assessment_type, members_assessed, avg_score, low_risk_count, moderate_risk_count, high_risk_count FROM red_bricks_insurance_catalog.care_management.gold_program_outcomes ORDER BY members_assessed DESC"
      ]
    }
  ],
