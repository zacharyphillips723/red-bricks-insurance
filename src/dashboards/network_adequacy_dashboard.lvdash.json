                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "bar",
              "encodings": {
                "x": { "fieldName": "county_type", "scale": { "type": "categorical" }, "displayName": "County Type" },
                "y": { "fieldName": "gap_members", "scale": { "type": "quantitative" }, "displayName": "Gap Members" },
                "color": { "fieldName": "county_type", "scale": { "type": "categorical" }, "displayName": "" }
              },
              "frame": { "showTitle": true, "title": "Members Without Access by County Type" }
            }
          },
          "position": { "x": 3, "y": 0, "width": 3, "height": 3 }
        },
        {
          "widget": {
            "name": "kpi-compliance",
            "queries": [{ "name": "main_query", "query": { "datasetName": "ds_overall_compliance", "fields": [{ "name": "overall_compliance_pct", "expression": "`overall_compliance_pct`" }], "disaggregated": true } }],
            "spec": { "version": 2, "widgetType": "counter", "encodings": { "value": { "fieldName": "overall_compliance_pct", "displayName": "%" } }, "frame": { "showTitle": true, "title": "Overall Compliance Rate" } }
