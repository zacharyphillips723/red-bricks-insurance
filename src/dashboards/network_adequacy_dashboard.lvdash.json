          },
          "position": { "x": 3, "y": 6, "width": 3, "height": 5 }
        },
        {
          "widget": {
            "name": "county-compliance-table",
            "queries": [{ "name": "main_query", "query": { "datasetName": "ds_compliance_by_county", "fields": [{ "name": "county_name", "expression": "`county_name`" }, { "name": "county_type", "expression": "`county_type`" }, { "name": "compliant_specialties", "expression": "`compliant_specialties`" }, { "name": "non_compliant_specialties", "expression": "`non_compliant_specialties`" }, { "name": "compliance_rate_pct", "expression": "`compliance_rate_pct`" }, { "name": "total_gap_members", "expression": "`total_gap_members`" }], "disaggregated": true } }],
            "spec": { "version": 2, "widgetType": "table", "encodings": { "columns": [{ "fieldName": "county_name", "displayName": "County" }, { "fieldName": "county_type", "displayName": "Type" }, { "fieldName": "compliant_specialties", "displayName": "Compliant" }, { "fieldName": "non_compliant_specialties", "displayName": "Non-Compliant" }, { "fieldName": "compliance_rate_pct", "displayName": "Rate %" }, { "fieldName": "total_gap_members", "displayName": "Gap Members" }] }, "frame": { "showTitle": true, "title": "Compliance by County — Detail" } }
          },
          "position": { "x": 0, "y": 11, "width": 6, "height": 6 }
        }
      ]
    },
