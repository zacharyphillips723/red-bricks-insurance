{
  "datasets": [
    {
      "name": "ds_overall_compliance",
      "displayName": "Overall Compliance Rate",
      "queryLines": [
        "SELECT ROUND(SUM(CASE WHEN is_compliant THEN 1 ELSE 0 END) * 100.0 / COUNT(*), 1) AS overall_compliance_pct, COUNT(*) AS total_county_specialty_combos, SUM(CASE WHEN is_compliant THEN 0 ELSE 1 END) AS non_compliant_count FROM network.gold_network_adequacy_compliance"
      ]
    },
    {
      "name": "ds_total_gap_members",
      "displayName": "Total Gap Members",
      "queryLines": [
        "SELECT SUM(gap_members) AS total_gap_members FROM network.gold_network_adequacy_compliance WHERE is_compliant = FALSE"
      ]
    },
    {
      "name": "ds_ghost_network_count",
      "displayName": "Ghost Network Providers",
      "queryLines": [
        "SELECT COUNT(*) AS ghost_count FROM network.gold_ghost_network_flags WHERE is_ghost_flagged = TRUE"
      ]
    },
    {
      "name": "ds_total_leakage_cost",
      "displayName": "Total OON Leakage Cost",
      "queryLines": [
        "SELECT ROUND(SUM(total_leakage_cost), 0) AS total_leakage FROM network.gold_leakage_summary"
      ]
    },
    {
      "name": "ds_telehealth_credit_impact",
      "displayName": "Telehealth Credit Impact",
      "queryLines": [
        "SELECT SUM(CASE WHEN telehealth_credit_applied THEN 1 ELSE 0 END) AS credit_applied_count FROM network.gold_network_adequacy_compliance"
      ]
    },
    {
      "name": "ds_compliance_by_county",
      "displayName": "Compliance by County",
      "queryLines": [
        "SELECT county_name, county_type, COUNT(*) AS specialties_measured, SUM(CASE WHEN is_compliant THEN 1 ELSE 0 END) AS compliant_specialties, SUM(CASE WHEN NOT is_compliant THEN 1 ELSE 0 END) AS non_compliant_specialties, ROUND(SUM(CASE WHEN is_compliant THEN 1 ELSE 0 END) * 100.0 / COUNT(*), 1) AS compliance_rate_pct, SUM(gap_members) AS total_gap_members FROM network.gold_network_adequacy_compliance GROUP BY county_name, county_type ORDER BY compliance_rate_pct ASC"
      ]
    },
    {
      "name": "ds_compliance_by_specialty",
      "displayName": "Compliance by Specialty",
      "queryLines": [
        "SELECT cms_specialty_type, COUNT(DISTINCT county_fips) AS counties_measured, SUM(CASE WHEN is_compliant THEN 1 ELSE 0 END) AS compliant_counties, SUM(CASE WHEN NOT is_compliant THEN 1 ELSE 0 END) AS non_compliant_counties, ROUND(SUM(CASE WHEN is_compliant THEN 1 ELSE 0 END) * 100.0 / COUNT(*), 1) AS compliance_rate_pct, SUM(gap_members) AS total_gap_members, ROUND(AVG(avg_nearest_distance_mi), 1) AS avg_distance_mi FROM network.gold_network_adequacy_compliance GROUP BY cms_specialty_type ORDER BY compliance_rate_pct ASC"
      ]
    },
    {
      "name": "ds_compliance_heatmap",
      "displayName": "Compliance Heatmap (County x Specialty)",
      "queryLines": [
        "SELECT county_name, cms_specialty_type, pct_compliant, is_compliant, gap_members, telehealth_credit_applied FROM network.gold_network_adequacy_compliance ORDER BY county_name, cms_specialty_type"
      ]
    },
    {
      "name": "ds_ghost_by_severity",
      "displayName": "Ghost Network by Severity",
      "queryLines": [
        "SELECT ghost_severity, COUNT(*) AS provider_count, SUM(impact_members) AS total_impact_members FROM network.gold_ghost_network_flags WHERE is_ghost_flagged = TRUE GROUP BY ghost_severity ORDER BY CASE ghost_severity WHEN 'High' THEN 1 WHEN 'Medium' THEN 2 WHEN 'Low' THEN 3 ELSE 4 END"
      ]
    },
    {
      "name": "ds_ghost_by_signal",
      "displayName": "Ghost Network Signal Breakdown",
      "queryLines": [
        "SELECT 'No Claims 12m' AS signal, SUM(CAST(no_claims_12m AS INT)) AS count FROM network.gold_ghost_network_flags WHERE is_ghost_flagged UNION ALL SELECT 'Not Accepting Patients', SUM(CAST(not_accepting AS INT)) FROM network.gold_ghost_network_flags WHERE is_ghost_flagged UNION ALL SELECT 'Credential Expired', SUM(CAST(credential_expired AS INT)) FROM network.gold_ghost_network_flags WHERE is_ghost_flagged UNION ALL SELECT 'Extreme Wait (>45d)', SUM(CAST(extreme_wait AS INT)) FROM network.gold_ghost_network_flags WHERE is_ghost_flagged UNION ALL SELECT 'Panel Full', SUM(CAST(panel_full AS INT)) FROM network.gold_ghost_network_flags WHERE is_ghost_flagged ORDER BY count DESC"
      ]
    },
    {
      "name": "ds_ghost_providers",
      "displayName": "Ghost Network Provider Detail",
      "queryLines": [
        "SELECT npi, provider_name, specialty, county, ghost_severity, ghost_signal_count, impact_members, credentialing_status, accepts_new_patients, appointment_wait_days, last_claims_date FROM network.gold_ghost_network_flags WHERE is_ghost_flagged = TRUE ORDER BY CASE ghost_severity WHEN 'High' THEN 1 WHEN 'Medium' THEN 2 ELSE 3 END, impact_members DESC"
      ]
    },
    {
      "name": "ds_leakage_by_specialty",
      "displayName": "OON Leakage by Specialty",
      "queryLines": [
        "SELECT cms_specialty_type, SUM(total_oon_claims) AS total_claims, ROUND(SUM(total_oon_paid), 0) AS total_paid, ROUND(SUM(total_leakage_cost), 0) AS leakage_cost, SUM(total_oon_members) AS unique_members, SUM(oon_provider_count) AS oon_providers FROM network.gold_leakage_summary GROUP BY cms_specialty_type ORDER BY leakage_cost DESC"
      ]
    },
    {
      "name": "ds_leakage_by_reason",
      "displayName": "Leakage by Reason",
      "queryLines": [
        "SELECT leakage_reason, SUM(claim_count) AS total_claims, ROUND(SUM(total_leakage_cost), 0) AS leakage_cost, SUM(unique_members) AS unique_members FROM network.gold_network_leakage GROUP BY leakage_reason ORDER BY leakage_cost DESC"
      ]
    },
    {
      "name": "ds_leakage_by_county",
      "displayName": "Leakage by County",
      "queryLines": [
        "SELECT county_name, county_type, SUM(total_oon_claims) AS total_claims, ROUND(SUM(total_leakage_cost), 0) AS leakage_cost, SUM(total_oon_members) AS unique_members FROM network.gold_leakage_summary GROUP BY county_name, county_type ORDER BY leakage_cost DESC"
      ]
    },
    {
      "name": "ds_recruitment_targets",
      "displayName": "Provider Recruitment Targets",
      "queryLines": [
        "SELECT rendering_provider_npi, specialty, county_name, total_claims, ROUND(total_paid, 0) AS total_paid, ROUND(potential_savings, 0) AS potential_savings, members_served, ROUND(avg_member_distance_mi, 1) AS avg_distance, ROUND(recruitment_priority_score, 0) AS priority_score FROM network.gold_provider_recruitment_targets ORDER BY recruitment_priority_score DESC LIMIT 20"
      ]
    },
    {
      "name": "ds_network_gaps",
      "displayName": "Network Gaps",
      "queryLines": [
        "SELECT county_name, county_type, cms_specialty_type, ROUND(pct_compliant, 1) AS compliance_pct, gap_members, gap_status, priority_rank, cms_threshold_miles, ROUND(avg_nearest_distance_mi, 1) AS avg_distance_mi, telehealth_credit_applied FROM network.gold_network_gaps WHERE priority_rank <= 3 ORDER BY priority_rank, gap_members DESC"
      ]
    },
    {
      "name": "ds_compliance_by_county_type",
      "displayName": "Compliance by County Type",
      "queryLines": [
        "SELECT county_type, COUNT(*) AS total_combos, SUM(CASE WHEN is_compliant THEN 1 ELSE 0 END) AS compliant, ROUND(SUM(CASE WHEN is_compliant THEN 1 ELSE 0 END) * 100.0 / COUNT(*), 1) AS compliance_rate_pct, SUM(gap_members) AS gap_members FROM network.gold_network_adequacy_compliance GROUP BY county_type ORDER BY CASE county_type WHEN 'Large Metro' THEN 1 WHEN 'Metro' THEN 2 WHEN 'Micro' THEN 3 WHEN 'Rural' THEN 4 WHEN 'CEAC' THEN 5 END"
      ]
    }
  ],
