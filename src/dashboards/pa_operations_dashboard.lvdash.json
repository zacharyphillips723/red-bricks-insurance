{
  "datasets": [
    {
      "name": "ds_pa_volume_trend",
      "displayName": "PA Volume by Month",
      "queryLines": [
        "SELECT reporting_month, total_requests, approved_count, denied_count, pended_count, partially_approved_count FROM prior_auth.gold_pa_metrics ORDER BY reporting_month"
      ]
    },
    {
      "name": "ds_approval_rate",
      "displayName": "Current Approval Rate",
      "queryLines": [
        "SELECT ROUND(AVG(approval_rate) * 100, 1) AS approval_rate_pct FROM prior_auth.gold_pa_metrics WHERE reporting_month >= DATE_TRUNC('month', CURRENT_DATE()) - INTERVAL 3 MONTHS"
      ]
    },
    {
      "name": "ds_avg_turnaround",
      "displayName": "Average Turnaround Hours",
      "queryLines": [
        "SELECT ROUND(AVG(avg_turnaround_hours), 1) AS avg_turnaround_hours FROM prior_auth.gold_pa_metrics WHERE reporting_month >= DATE_TRUNC('month', CURRENT_DATE()) - INTERVAL 3 MONTHS"
      ]
    },
    {
      "name": "ds_cms_compliance",
      "displayName": "CMS Compliance Rate",
      "queryLines": [
        "SELECT ROUND(AVG(cms_compliance_rate) * 100, 1) AS compliance_pct FROM prior_auth.gold_pa_metrics WHERE reporting_month >= DATE_TRUNC('month', CURRENT_DATE()) - INTERVAL 3 MONTHS"
      ]
    },
    {
      "name": "ds_appeal_overturn",
      "displayName": "Appeal Overturn Rate",
      "queryLines": [
        "SELECT ROUND(AVG(appeal_overturn_rate) * 100, 1) AS overturn_pct FROM prior_auth.gold_pa_metrics WHERE reporting_month >= DATE_TRUNC('month', CURRENT_DATE()) - INTERVAL 3 MONTHS AND appeal_overturn_rate IS NOT NULL"
      ]
    },
    {
      "name": "ds_turnaround_by_urgency",
      "displayName": "Turnaround by Urgency",
      "queryLines": [
        "SELECT reporting_month, avg_expedited_turnaround_hours, avg_standard_turnaround_hours FROM prior_auth.gold_pa_metrics ORDER BY reporting_month"
      ]
    },
    {
      "name": "ds_turnaround_distribution",
      "displayName": "Turnaround Distribution vs CMS Thresholds",
      "queryLines": [
        "SELECT urgency, ROUND(turnaround_hours, 0) AS turnaround_hours_bucket, COUNT(*) AS request_count FROM prior_auth.gold_pa_requests WHERE turnaround_hours IS NOT NULL GROUP BY urgency, ROUND(turnaround_hours, 0) ORDER BY urgency, turnaround_hours_bucket"
      ]
    },
    {
      "name": "ds_auto_adjudication_funnel",
      "displayName": "Auto-Adjudication Funnel",
      "queryLines": [
        "SELECT determination_tier, COUNT(*) AS request_count, ROUND(AVG(CASE WHEN determination = 'approved' THEN 1 ELSE 0 END) * 100, 1) AS approval_rate_pct, ROUND(AVG(turnaround_hours), 1) AS avg_turnaround FROM prior_auth.gold_pa_requests GROUP BY determination_tier ORDER BY CASE determination_tier WHEN 'tier_1_auto' THEN 1 WHEN 'tier_2_ml' THEN 2 WHEN 'tier_3_llm' THEN 3 ELSE 4 END"
      ]
    },
    {
      "name": "ds_denial_reasons",
      "displayName": "Top Denial Reasons",
      "queryLines": [
        "SELECT denial_reason_code, denial_reason_display, total_denials, appeal_rate_pct, overturn_rate_pct FROM prior_auth.gold_pa_denial_analysis WHERE denial_reason_code IS NOT NULL ORDER BY total_denials DESC LIMIT 10"
      ]
    },
    {
      "name": "ds_service_type_breakdown",
      "displayName": "Approval/Denial by Service Type",
      "queryLines": [
        "SELECT service_type, COUNT(*) AS total, SUM(CASE WHEN determination = 'approved' THEN 1 ELSE 0 END) AS approved, SUM(CASE WHEN determination = 'denied' THEN 1 ELSE 0 END) AS denied, SUM(CASE WHEN determination = 'pended' THEN 1 ELSE 0 END) AS pended, ROUND(AVG(CASE WHEN determination = 'approved' THEN 1 ELSE 0 END) * 100, 1) AS approval_rate_pct FROM prior_auth.gold_pa_requests GROUP BY service_type ORDER BY total DESC"
      ]
    },
    {
      "name": "ds_provider_leaderboard",
      "displayName": "Provider PA Patterns",
      "queryLines": [
        "SELECT provider_name, provider_specialty, total_requests, approval_rate_pct, denial_rate_pct, avg_turnaround_hours, auto_adjudication_rate_pct FROM prior_auth.gold_pa_provider_patterns ORDER BY total_requests DESC LIMIT 15"
      ]
    },
    {
      "name": "ds_policy_utilization",
      "displayName": "Policy Utilization",
      "queryLines": [
        "SELECT policy_name, service_category, total_requests, approval_rate_pct, denial_rate_pct, top_denial_reason FROM prior_auth.gold_pa_policy_utilization ORDER BY total_requests DESC"
      ]
    },
    {
      "name": "ds_total_requests",
      "displayName": "Total PA Requests",
      "queryLines": [
        "SELECT COUNT(*) AS total_requests FROM prior_auth.gold_pa_requests"
      ]
    },
    {
      "name": "ds_auto_adjudication_rate",
      "displayName": "Auto-Adjudication Rate",
      "queryLines": [
        "SELECT ROUND(SUM(CASE WHEN determination_tier IN ('tier_1_auto', 'tier_2_ml') THEN 1 ELSE 0 END) * 100.0 / COUNT(*), 1) AS auto_rate_pct FROM prior_auth.gold_pa_requests"
      ]
    },
    {
      "name": "ds_cost_by_determination",
      "displayName": "Cost by Determination",
      "queryLines": [
        "SELECT determination, COUNT(*) AS count, ROUND(SUM(estimated_cost), 0) AS total_cost, ROUND(AVG(estimated_cost), 0) AS avg_cost FROM prior_auth.gold_pa_requests GROUP BY determination ORDER BY total_cost DESC"
      ]
    }
  ],
